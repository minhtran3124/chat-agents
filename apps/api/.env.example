LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6   # optional, defaults from provider

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

TAVILY_API_KEY=tvly-...

CHECKPOINT_DB_PATH=./data/checkpoints.sqlite
VFS_OFFLOAD_THRESHOLD_TOKENS=20000
COMPRESSION_DETECTION_RATIO=0.7
# Research endpoint timeout in seconds (10-3600, default 500)
RESEARCH_TIMEOUT_S=500
CORS_ORIGINS=["http://localhost:3000"]

# Logging: INFO (default) | DEBUG (verbose, shows per-chunk events)
# LOG_LEVEL=DEBUG

# Token budget per research run (default 200000)
# MAX_TOKENS_PER_RUN=200000

# LangSmith tracing (optional — omit to disable)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_PROJECT=chat-agents
